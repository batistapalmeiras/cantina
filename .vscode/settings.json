{
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": "\\.(ts|tsx)$",
        "cmd": "node ${workspaceRoot}/scripts/sort-imports.js ${file}"
      }
    ]
  }
}

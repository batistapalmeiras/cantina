{
  "name": "bp-ui",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --target es2018",
    "dev": "tsup src/index.ts --format esm,cjs --dts --target es2018 --watch"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:",
    "styled-components": "catalog:"
  },
  "dependencies": {
    "bp-core": "workspace:*",
    "lucide-react": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/styled-components": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
